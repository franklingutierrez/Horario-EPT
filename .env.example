# ============================================================
#  Horario-EPT — Variables de entorno
#  Copiar este archivo a .env y completar los valores
# ============================================================

# Base de datos MySQL
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=horario_ept
MYSQL_USER=horario_user
MYSQL_PASSWORD=changeme_user_password

# Seguridad JWT (cambiar por un string largo y aleatorio)
JWT_SECRET=changeme_jwt_secret_very_long_random_string_here

# Puerto de la aplicación (default: 8087)
APP_PORT=8087
